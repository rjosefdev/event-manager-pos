{
  "name": "event-manager-pos",
  "private": true,
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "concurrently -n web,api \"pnpm dev:web\" \"pnpm dev:api\"",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:api": "pnpm --dir apps/api dev",
    "build": "pnpm build:web && pnpm build:api",
    "build:web": "pnpm --dir apps/web build",
    "build:api": "pnpm --dir apps/api build",
    "test": "pnpm test:web && pnpm test:api",
    "test:web": "pnpm --dir apps/web test",
    "test:api": "pnpm --dir apps/api test",
    "lint": "pnpm --dir apps/web lint"
  },
  "devDependencies": {
    "concurrently": "latest"
  }
}